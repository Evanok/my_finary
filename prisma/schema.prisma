generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id           String        @id @default(cuid())
  name         String
  institution  String
  type         String        // CELI, REER, TFSA, taxable, etc.
  createdAt    DateTime      @default(now())
  transactions Transaction[]
}

model Asset {
  id             String        @id @default(cuid())
  symbol         String        @unique
  name           String
  category       String        // ETF, stock, crypto, etc.
  nativeCurrency String        @default("USD") // currency returned by the exchange (USD, CAD, EUR)
  createdAt      DateTime      @default(now())
  transactions   Transaction[]
  priceCache     PriceCache[]
}

model Transaction {
  id        String   @id @default(cuid())
  accountId String
  assetId   String
  date      DateTime
  quantity  Float
  price     Float    // purchase price per unit in original currency
  currency  String   @default("USD") // currency of the transaction at time of purchase
  type      String   // buy, sell
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id])
  asset   Asset   @relation(fields: [assetId], references: [id])
}

model PriceCache {
  id        String   @id @default(cuid())
  assetId   String
  source    String   // yahoo, finnhub, coingecko, coincap
  priceUsd  Float    // always stored in USD
  fetchedAt DateTime @default(now())
  validated Boolean  @default(false)

  asset Asset @relation(fields: [assetId], references: [id])

  @@unique([assetId, source])
}

model FxRateCache {
  id        String   @id @default(cuid())
  pair      String   @unique // e.g. "EUR/USD", "CAD/USD"
  rate      Float    // how many USD for 1 unit of base currency
  fetchedAt DateTime @default(now())
}

model PortfolioSnapshot {
  id         String   @id @default(cuid())
  date       DateTime @unique // one snapshot per day (date only, time = 00:00:00)
  totalUsd   Float    // total portfolio value in USD at snapshot time
  breakdown  String   // JSON: { assetId, symbol, quantity, priceUsd, valueUsd }[]
  createdAt  DateTime @default(now())
}
